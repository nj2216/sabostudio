{
  "name": "sabostudio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"server,vite\" --prefix-colors \"cyan,magenta\" \"node --watch server/index.js\" \"npm run dev --prefix frontend\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
