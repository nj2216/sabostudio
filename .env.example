# Environment (development | production)
# development → SQLite local DB (no external DB needed, file: dev.db)
# production  → Supabase (fill in SUPABASE_* variables below)
NODE_ENV=development

# Supabase configuration — required only when NODE_ENV=production
# Get these from your Supabase project dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server port (defaults to 3000)
PORT=3000

# PeerJS — default cloud broker (peerjs.com) is used by default.
# Only set PEERJS_HOST/PORT/PATH if you are running a self-hosted PeerServer.
# PEERJS_HOST=
# PEERJS_PORT=
# PEERJS_PATH=/
